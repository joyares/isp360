APP_ENV=local
APP_DEBUG=1
APP_URL=http://localhost/isp360/public

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=isp360
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Optional for git db hooks (Laragon default shown)
MYSQL_BIN_DIR=D:/laragon/bin/mysql/mysql-8.0.30-winx64/bin
DB_DUMP_MAX_MB=50

# On Linux servers you can set MYSQL_BIN_DIR=/usr/bin or leave empty if mysql/mysqldump are in PATH
